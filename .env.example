# Creator Compass Environment Configuration

# Copy this files contents to .env and fill in your actual credentials

# REQUIRED: Apify API Token for Twitter trend data
# Get it from: https://apify.com/account/info
# Note: Apify has a free tier with limitations
APIFY_API_TOKEN=your_apify_token_here

# REQUIRED: OpenAI API Key for GPT-4o-mini content generation
# Get it from: https://platform.openai.com/account/api-keys
# Note: Requires paid account (free trial has limitations)
OPENAI_API_KEY=your_openai_api_key_here

